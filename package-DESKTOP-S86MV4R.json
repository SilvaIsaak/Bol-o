{
  "name": "bolao-2026",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm --prefix client run dev\" \"npm --prefix server run dev\"",
    "dev:client": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build": "npm --prefix client run build && npm --prefix server run build",
    "test": "npm --prefix server run test",
    "install:all": "npm install --prefix client && npm install --prefix server"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "xlsx": "^0.18.5"
  },
  "description": "Este é um sistema completo para gerenciamento de bolão da Copa do Mundo 2026, com funcionalidades para usuários e administradores.",
  "main": "index.js",
  "dependencies": {
    "ansi-regex": "^6.2.2",
    "ansi-styles": "^6.2.3",
    "chalk": "^5.6.2",
    "cliui": "^9.0.1",
    "emoji-regex": "^10.6.0",
    "escalade": "^3.2.0",
    "get-caller-file": "^2.0.5",
    "get-east-asian-width": "^1.6.0",
    "rxjs": "^7.8.2",
    "shell-quote": "^1.8.4",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.2.0",
    "supports-color": "^10.2.2",
    "tree-kill": "^1.2.2",
    "tslib": "^2.8.1",
    "wrap-ansi": "^9.0.2",
    "y18n": "^5.0.8",
    "yargs": "^18.0.0",
    "yargs-parser": "^22.0.0"
  },
  "keywords": [],
